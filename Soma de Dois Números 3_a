#include <stdio.h>

int main() {
    // Declaração das variáveis
    int num1, num2, soma;

    // Leitura dos números
    printf("Digite o primeiro número: ");
    scanf("%d", &num1);

    printf("Digite o segundo número: ");
    scanf("%d", &num2);

    // Realizando a soma
    soma = num1 + num2;

    // Exibindo o resultado
    printf("A soma de %d e %d é %d\n", num1, num2, soma);

    return 0;
}
